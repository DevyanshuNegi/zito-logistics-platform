{
  "expo": {
    "name": "ZITO",
    "slug": "zito-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zito",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f121c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zito.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ZITO needs your location to track trips.",
        "NSCameraUsageDescription": "ZITO needs camera for Proof of Delivery photos.",
        "NSPhotoLibraryUsageDescription": "ZITO needs photo library access for document uploads."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f121c"
      },
      "package": "com.zito.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-splash-screen",
        { "image": "./assets/images/splash-icon.png", "backgroundColor": "#0f121c", "imageWidth": 200 }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://your-render-backend.onrender.com"
    }
  }
}

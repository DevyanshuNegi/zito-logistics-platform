{
  "name": "zito-backend",
  "version": "1.0.0",
  "description": "Zito Logistics Platform — Backend API · Aurenza Limited",
  "author": "Aurenza Limited",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:dev:clean": "node scripts/free-port.js 5000 && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "neon:validate": "node scripts/validate-neon-env.js",
    "deploy:neon": "npm run neon:validate && npm run prisma:generate && npm run prisma:migrate:deploy && npm run build",
    "dev:express": "nodemon server.js",
    "test": "jest --config tests/jest.config.js",
    "test:watch": "jest --watch --config tests/jest.config.js",
    "test:coverage": "jest --coverage --config tests/jest.config.js",
    "test:ci": "jest --ci --coverage --config tests/jest.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "africastalking": "^0.7.9",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "glob": "^13.0.6",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishal31987-rgb/zito-backend.git"
  },
  "keywords": [
    "logistics",
    "zito",
    "kenya",
    "freight",
    "api"
  ],
  "bugs": {
    "url": "https://github.com/vishal31987-rgb/zito-backend/issues"
  },
  "homepage": "https://github.com/vishal31987-rgb/zito-backend#readme",
  "directories": {
    "test": "tests"
  }
}

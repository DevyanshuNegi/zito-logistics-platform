# ─────────────────────────────────────────────────────────────

# ZITO — .gitignore (FINAL)

# Covers backend + frontend + mobile (Expo)

# ─────────────────────────────────────────────────────────────

# ── Environment variables — NEVER commit ─────────────────────

.env
.env.local
.env.development
.env.production
.env.staging
.env.*

# ── Dependencies ─────────────────────────────────────────────

node_modules/
backend/node_modules/
frontend/node_modules/
zito-mobile/node_modules/

# ── Logs ─────────────────────────────────────────────────────

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime / Process ────────────────────────────────────────

pids/
*.pid
*.seed
*.pid.lock

# ── Build output ─────────────────────────────────────────────

dist/
build/
frontend/dist/
backend/dist/

# ── OS files ─────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Coverage & Testing ───────────────────────────────────────

coverage/
.nyc_output/

# ── Uploads / user-generated files ───────────────────────────

uploads/
backend/uploads/

# ── Expo / React Native (IMPORTANT) ──────────────────────────

.expo/
.expo-shared/

# ── Cache / Temp ─────────────────────────────────────────────

.tmp/
.cache/

# ── Deployment Vendor / Runtime ─────────────────────────────


# ── Keep lock files (IMPORTANT — DO NOT IGNORE) ──────────────

# package-lock.json

# yarn.lock

/src/generated/prisma

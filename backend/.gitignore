# ─────────────────────────────────────────────
# ZITO — MASTER .gitignore
# Backend + Frontend + Expo Mobile
# ─────────────────────────────────────────────

# ============================================
# ENV / SECRETS
# ============================================

.env
.env.*
!.env.example

# ============================================
# NODE MODULES
# ============================================

node_modules/
**/node_modules/

# ============================================
# BUILD OUTPUTS
# ============================================

dist/
build/
.next/
out/
coverage/

# ============================================
# LOG FILES
# ============================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ============================================
# TEMP / CACHE
# ============================================

.tmp/
.temp/
.cache/
.parcel-cache/

# ============================================
# OS FILES
# ============================================

.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# IDE / EDITOR
# ============================================

.vscode/
.idea/
*.swp
*.swo

# ============================================
# EXPO / REACT NATIVE
# ============================================

.expo/
.expo-shared/

# Native build folders
android/
ios/

# ============================================
# UPLOADS / GENERATED FILES
# ============================================

uploads/
public/uploads/

# ============================================
# SECURITY FILES
# ============================================

*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

# ============================================
# FIREBASE / GOOGLE
# ============================================

firebase-adminsdk*.json
google-services.json
GoogleService-Info.plist

# ============================================
# DATABASE
# ============================================

*.sqlite
*.db

# ============================================
# RUNTIME
# ============================================

pids/
*.pid
*.seed
*.pid.lock

# ============================================
# DOCKER
# ============================================

.docker/

# ============================================
# MISC
# ============================================

*.tgz
*.zip

# ============================================
# IMPORTANT
# Keep lock files for stable builds
# ============================================

# package-lock.json
# yarn.lock
# pnpm-lock.yaml
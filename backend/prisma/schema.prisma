// ============================================================
// ZITO Super App Platform — Prisma Schema
// PRD v10 ULTIMATE | NestJS + Neon PostgreSQL + PostGIS
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  AGENT
  TRANSPORTER
  COURIER_COMPANY
  WAREHOUSE_PARTNER
  AGENCY_STAFF
  ADMIN
  SUPER_ADMIN
  CORPORATE
}

enum AccountStatus {
  PENDING
  VERIFIED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum BookingStatus {
  CREATED
  SEARCHING
  APPROVED
  ASSIGNED
  ACCEPTED
  ARRIVED
  PICKED
  IN_TRANSIT
  ARRIVED_AT_DESTINATION
  DELIVERY_VERIFICATION
  DELIVERED
  PAYMENT_PENDING
  COMPLETED
  CANCELLED
  REJECTED
}

enum ServiceType {
  FTL
  PTL
  COURIER
  WAREHOUSE
  RAIL
}

enum BookingCapacitySource {
  OWNED_FLEET
  CFA_NETWORK
  BLENDED
}

enum InventoryStatus {
  RECEIVED
  STORED
  SORTED
  DISPATCHED
  DELIVERED
  MISSING
  DAMAGED
}

enum WaybillStatus {
  CREATED
  IN_TRANSIT
  DELIVERED
  CLOSED
}

enum LossReportStatus {
  PENDING
  INVESTIGATING
  ESCALATED
  RESOLVED
  CLAIMED
}

enum PaymentStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  REVERSED
  REFUNDED
}

enum PaymentMethod {
  MPESA
  CARD
  CASH
  WALLET
  BANK_TRANSFER
}

enum InvoiceType {
  TRANSPORT
  WAREHOUSE
  COURIER
  COMBINED
  PLATFORM
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  PARTIAL
}

enum RtoStatus {
  INITIATED
  IN_TRANSIT
  WAREHOUSE_RECEIVED
  CLOSED
}

enum VehicleType {
  MOTORBIKE
  VAN
  TRUCK_3T
  TRUCK_7T
  TRUCK_14T
  TRUCK_22T
  CONTAINER_20FT
  CONTAINER_40FT
  REFRIGERATED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SUSPENDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum ScanCheckpoint {
  PICKUP
  WAREHOUSE_ENTRY
  STORAGE
  DISPATCH
  DELIVERY
  VEHICLE_LOAD
  VEHICLE_UNLOAD
}

model User {
  id            String        @id @default(uuid())
  fullName      String?
  companyName   String?
  email         String?       @unique
  phone         String        @unique
  password      String?
  role          UserRole      @default(CUSTOMER)
  status        AccountStatus @default(PENDING)

  agencyId      String?
  agency        Agency?       @relation(fields: [agencyId], references: [id])

  driverProfile     Driver?
  kycDocuments      KycDocument[]
  managedWarehouses Warehouse[]     @relation("WarehouseManager")
  reportedLosses    LossReport[]    @relation("Reporter")
  reviewedLosses    LossReport[]    @relation("Reviewer")
  supportTickets    SupportTicket[] @relation("TicketRaiser")
  assignedTickets   SupportTicket[] @relation("TicketHandler")
  auditLogs         AuditLog[]
  wallets           Wallet[]
  notifications     Notification[]
  ownedDrivers      Driver[]        @relation("DriverOwner")
  ownedVehicles     Vehicle[]       @relation("VehicleOwner")

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model KycDocument {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  type             String
  fileUrl          String
  status           String    @default("PENDING")
  documentNumber   String?
  issuingAuthority String?
  countryOfIssue   String?
  documentSide     String?
  issueDate        DateTime?
  expiryDate       DateTime?
  reviewNote       String?
  rejectionReason  String?
  verifiedAt       DateTime?
  verifiedBy       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Agency {
  id          String    @id @default(uuid())
  name        String
  address     String?
  latitude    Float?
  longitude   Float?
  managerId   String?
  status      String    @default("ACTIVE")

  users       User[]
  warehouses  Warehouse[]
  bookings    Booking[]
  staff       Staff[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Staff {
  id        String   @id @default(uuid())
  userId    String   @unique
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  ownerUserId      String?
  ownerUser        User?     @relation("DriverOwner", fields: [ownerUserId], references: [id])

  isOnline         Boolean   @default(false)
  isAvailable      Boolean   @default(true)
  currentLatitude  Float?
  currentLongitude Float?
  lastLocationAt   DateTime?

  rating           Float     @default(5.0)
  completionRate   Float     @default(0)
  acceptanceRate   Float     @default(0)
  totalTrips       Int       @default(0)

  licenseNumber    String?
  licenseExpiry    DateTime?
  licenseVerified  Boolean   @default(false)
  isBlacklisted    Boolean   @default(false)

  vehicle          Vehicle?          @relation("AssignedVehicle")
  shifts           DriverShift[]
  payrolls         DriverPayroll[]
  incentives       DriverIncentive[]
  penalties        DriverPenalty[]
  bookings         Booking[]         @relation("AssignedDriver")
  fuelLogs         FuelLog[]
  breakdowns       VehicleBreakdown[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([currentLatitude, currentLongitude])
  @@index([ownerUserId])
}

model DriverShift {
  id               String           @id @default(uuid())
  driverId         String
  driver           Driver           @relation(fields: [driverId], references: [id])

  shiftStartTime   DateTime
  shiftEndTime     DateTime?
  totalHours       Float?
  tripHours        Float?
  idleHours        Float?
  attendanceStatus AttendanceStatus  @default(PRESENT)
  status           String           @default("ACTIVE")

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model DriverPayroll {
  id             String    @id @default(uuid())
  driverId       String
  driver         Driver    @relation(fields: [driverId], references: [id])

  periodStart    DateTime
  periodEnd      DateTime
  totalTrips     Int       @default(0)
  tripEarnings   Float     @default(0)
  hourlyEarnings Float     @default(0)
  incentiveTotal Float     @default(0)
  penaltyTotal   Float     @default(0)
  netPayout      Float     @default(0)
  status         String    @default("PENDING")

  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  transactionRef String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DriverIncentive {
  id        String   @id @default(uuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  type      String
  amount    Float
  reason    String?
  bookingId String?
  createdAt DateTime @default(now())
}

model DriverPenalty {
  id        String   @id @default(uuid())
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  type      String
  amount    Float
  reason    String
  bookingId String?
  createdAt DateTime @default(now())
}

model Vehicle {
  id                String        @id @default(uuid())
  plateNumber       String        @unique
  make              String?
  model             String?
  year              Int?
  type              VehicleType
  status            VehicleStatus @default(ACTIVE)

  capacityKg        Float
  capacityM3        Float?

  deviceGpsLat      Float?
  deviceGpsLng      Float?
  lastGpsAt         DateTime?

  insuranceExpiry   DateTime?
  insuranceVerified Boolean       @default(false)
  permitExpiry      DateTime?
  permitVerified    Boolean       @default(false)
  inspectionCertificateExpiry DateTime?
  verificationStatus String       @default("PENDING_REVIEW")
  verificationReviewedAt DateTime?
  verificationReviewedBy String?
  verificationNote  String?
  rejectionReason   String?

  ownerUserId       String?
  ownerUser         User?         @relation("VehicleOwner", fields: [ownerUserId], references: [id])
  driverId          String?       @unique
  driver            Driver?       @relation("AssignedVehicle", fields: [driverId], references: [id])

  bookings          Booking[]         @relation("BookingVehicle")
  fuelLogs          FuelLog[]
  breakdowns        VehicleBreakdown[]
  maintenanceLogs   MaintenanceLog[]
  verificationPhotos VehicleVerificationPhoto[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([ownerUserId])
  @@index([deviceGpsLat, deviceGpsLng])
}

model VehicleVerificationPhoto {
  id              String   @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  category        String
  fileUrl         String
  mimeType        String?
  status          String   @default("PENDING_REVIEW")
  capturedAt      DateTime?
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNote      String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([vehicleId, category])
}

model FuelLog {
  id           String   @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId     String?
  driver       Driver?  @relation(fields: [driverId], references: [id])
  bookingId    String?
  booking      Booking? @relation(fields: [bookingId], references: [id])

  fuelExpected Float
  fuelActual   Float
  fuelCost     Float
  variance     Float
  notes        String?
  isFlagged    Boolean  @default(false)

  createdAt    DateTime @default(now())
}

model VehicleBreakdown {
  id              String   @id @default(uuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id])
  bookingId       String?
  booking         Booking? @relation(fields: [bookingId], references: [id])

  description     String
  latitude        Float?
  longitude       Float?
  status          String   @default("REPORTED")
  backupVehicleId String?
  resolvedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MaintenanceLog {
  id          String    @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  type        String
  description String
  cost        Float?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Booking {
  id              String        @id @default(uuid())
  reference       String        @unique
  status          BookingStatus @default(CREATED)
  serviceType     ServiceType   @default(COURIER)
  capacitySource  BookingCapacitySource @default(CFA_NETWORK)

  customerId      String
  agencyId        String?
  agency          Agency?       @relation(fields: [agencyId], references: [id])

  driverId        String?
  driver          Driver?       @relation("AssignedDriver", fields: [driverId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?      @relation("BookingVehicle", fields: [vehicleId], references: [id])
  requiredVehicleType   VehicleType?
  baseFare        Float         @default(0)
  distanceFare    Float         @default(0)
  stopFare        Float         @default(0)
  surgeMultiplier Float         @default(1.0)
  totalPrice      Float         @default(0)
  estimatedDistKm Float         @default(0)

  cancelledAt        DateTime?
  cancellationReason String?
  cancelledBy        String?

  deliveryOtp      String?
  deliveryProofUrl String?
  deliveredAt      DateTime?

  idempotencyKey   String?       @unique

  cargoType           String?
  cargoWeightKg       Float?
  cargoDescription    String?
  specialInstructions String?
  isScheduled         Boolean       @default(false)

  stops          BookingStop[]
  parcels        InventoryItem[]
  waybills       Waybill[]
  lossReports    LossReport[]
  payments       Payment[]
  invoice        Invoice?
  escrow         Escrow?
  scanEvents     ScanEvent[]
  fuelLogs       FuelLog[]
  breakdowns     VehicleBreakdown[]
  supportTickets SupportTicket[]
  rtoReturn      RtoReturn?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model BookingStop {
  id           String    @id @default(uuid())
  bookingId    String
  booking      Booking   @relation(fields: [bookingId], references: [id])

  sequence     Int
  address      String
  latitude     Float
  longitude    Float
  landmark     String?
  contactName  String
  contactPhone String
  stopType     String

  arrivalTime  DateTime?
  completedAt  DateTime?
  otp          String?

  createdAt    DateTime  @default(now())
}

model RtoReturn {
  id          String     @id @default(uuid())
  bookingId   String     @unique
  booking     Booking    @relation(fields: [bookingId], references: [id])
  reason      String
  status      RtoStatus  @default(INITIATED)
  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model RateCard {
  id              String      @id @default(uuid())
  vehicleType     VehicleType
  serviceType     ServiceType
  countryCode     String      @default("KE")
  county          String?
  localityType    String      @default("ANY")
  baseFare        Float
  ratePerKm       Float
  perStopRate     Float       @default(0)
  minDistance     Float       @default(0)
  surgeMultiplier Float       @default(1.0)
  isActive        Boolean     @default(true)
  version         Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([countryCode, county, localityType, vehicleType, serviceType, isActive])
}

model Contract {
  id              String    @id @default(uuid())
  customerId      String
  agencyId        String?
  businessName    String
  creditLimit     Float     @default(0)
  creditUsed      Float     @default(0)
  billingCycle    String    @default("MONTHLY")
  paymentTermDays Int       @default(30)
  status          String    @default("ACTIVE")
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LoginOtp {
  id          String   @id @default(uuid())
  contact     String
  otp         String
  expiresAt   DateTime
  resendCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([contact])
}

model LoginAttempt {
  identifier    String    @id
  count         Int       @default(0)
  lastAttemptAt DateTime  @default(now())
  lockExpiresAt DateTime?
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  address   String?
  latitude  Float?
  longitude Float?
  status    String    @default("ACTIVE")

  agencyId  String
  agency    Agency    @relation(fields: [agencyId], references: [id])

  managerId String?
  manager   User?     @relation("WarehouseManager", fields: [managerId], references: [id])

  zones      WarehouseZone[]
  items      InventoryItem[]
  rtoReturns RtoReturn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarehouseZone {
  id          String    @id @default(uuid())
  name        String
  code        String
  type        String    @default("DRY")
  capacity    Float
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  racks       WarehouseRack[]
}

model WarehouseRack {
  id     String        @id @default(uuid())
  label  String
  zoneId String
  zone   WarehouseZone @relation(fields: [zoneId], references: [id])
  bins   WarehouseBin[]
}

model WarehouseBin {
  id         String        @id @default(uuid())
  label      String
  isOccupied Boolean       @default(false)
  rackId     String
  rack       WarehouseRack @relation(fields: [rackId], references: [id])
  items      InventoryItem[]
}

model InventoryItem {
  id       String          @id @default(uuid())
  parcelId String          @unique
  barcodeUrl String?

  bookingId String
  booking   Booking         @relation(fields: [bookingId], references: [id])

  waybillId String?
  waybill   Waybill?        @relation(fields: [waybillId], references: [id])

  ownerId   String

  status      InventoryStatus @default(RECEIVED)
  isFragile   Boolean         @default(false)
  isHazmat    Boolean         @default(false)
  weight      Float
  dimensions  String?
  expiryDate  DateTime?

  warehouseId      String?
  warehouse        Warehouse?    @relation(fields: [warehouseId], references: [id])
  binId            String?
  bin              WarehouseBin? @relation(fields: [binId], references: [id])
  currentVehicleId String?

  movements   InventoryMovement[]
  lossReports LossReport[]
  scanEvents  ScanEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryMovement {
  id                  String        @id @default(uuid())
  itemId              String
  item                InventoryItem @relation(fields: [itemId], references: [id])
  status              String
  locationDescription String
  remarks             String?
  performedBy         String
  createdAt           DateTime      @default(now())
}

model ScanEvent {
  id        String        @id @default(uuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])

  bookingId String?
  booking   Booking?      @relation(fields: [bookingId], references: [id])
  waybillId String?
  waybill   Waybill?      @relation(fields: [waybillId], references: [id])
  vehicleId String?
  driverId  String?

  checkpoint  ScanCheckpoint
  latitude    Float?
  longitude   Float?
  performedBy String
  notes       String?

  createdAt DateTime @default(now())
}

model Waybill {
  id          String        @id @default(uuid())
  number      String        @unique
  type        String        @default("WAYBILL")
  status      WaybillStatus @default(CREATED)
  isLocked    Boolean       @default(false)

  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id])

  items      InventoryItem[]
  scanEvents ScanEvent[]

  issuedAt    DateTime  @default(now())
  deliveredAt DateTime?
}

model LossReport {
  id              String           @id @default(uuid())
  bookingId       String
  booking         Booking          @relation(fields: [bookingId], references: [id])

  itemId          String?
  item            InventoryItem?   @relation(fields: [itemId], references: [id])

  type            String
  description     String
  estimatedValue  Float
  status          LossReportStatus @default(PENDING)
  resolutionNotes String?
  evidenceUrls    String[]

  isHighValue          Boolean @default(false)
  requiresDualApproval Boolean @default(false)

  reportedBy String
  reporter   User             @relation("Reporter", fields: [reportedBy], references: [id])
  reviewerId String?
  reviewer   User?            @relation("Reviewer", fields: [reviewerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id             String        @id @default(uuid())
  bookingId      String?
  booking        Booking?      @relation(fields: [bookingId], references: [id])
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])

  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(INITIATED)
  reference      String?
  proofUrl       String?
  idempotencyKey String?       @unique
  retryCount     Int           @default(0)
  failureReason  String?
  reversedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([invoiceId])
}

model Wallet {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  balance  Float    @default(0)
  currency String   @default("KES")

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id             String   @id @default(uuid())
  walletId       String
  wallet         Wallet   @relation(fields: [walletId], references: [id])
  type           String
  amount         Float
  balance        Float
  reference      String?
  description    String?
  bookingId      String?
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
}

model Escrow {
  id          String       @id @default(uuid())
  bookingId   String       @unique
  booking     Booking      @relation(fields: [bookingId], references: [id])
  amount      Float
  status      EscrowStatus @default(HELD)
  heldAt      DateTime     @default(now())
  releasedAt  DateTime?
  refundedAt  DateTime?
  releaseNote String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Invoice {
  id       String        @id @default(uuid())
  number   String        @unique
  type     InvoiceType
  status   InvoiceStatus @default(DRAFT)
  isLocked Boolean       @default(false)

  bookingId  String?  @unique
  booking    Booking? @relation(fields: [bookingId], references: [id])
  customerId String
  agencyId   String?

  subtotal    Float
  taxAmount   Float    @default(0)
  totalAmount Float
  paidAmount  Float    @default(0)
  dueDate     DateTime?
  issuedAt    DateTime?
  paidAt      DateTime?

  isApprovalRequired Boolean   @default(false)
  approvedBy         String?
  approvedAt         DateTime?

  payments Payment[]
  lineItems InvoiceLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float
}

model SupportTicket {
  id        String       @id @default(uuid())
  bookingId String?
  booking   Booking?     @relation(fields: [bookingId], references: [id])

  raisedBy  String
  raiser    User         @relation("TicketRaiser", fields: [raisedBy], references: [id])
  handlerId String?
  handler   User?        @relation("TicketHandler", fields: [handlerId], references: [id])

  category        String
  description     String
  status          TicketStatus @default(OPEN)
  priority        String       @default("MEDIUM")
  resolution      String?
  closedAt        DateTime?
  escalationLevel Int          @default(1)
  escalatedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  title      String
  message    String
  channel    String
  status     String    @default("PENDING")
  retryCount Int       @default(0)
  readAt     DateTime?
  entityType String?
  entityId   String?
  createdAt  DateTime  @default(now())
}

model InternalAlert {
  id         String   @id @default(uuid())
  type       String
  severity   String   @default("MEDIUM")
  message    String
  status     String   @default("PENDING")
  agencyId   String?
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())
}

model FraudFlag {
  id          String    @id @default(uuid())
  entityType  String
  entityId    String
  type        String
  description String
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model SurgeZone {
  id              String    @id @default(uuid())
  name            String
  latitude        Float
  longitude       Float
  radiusKm        Float
  surgeMultiplier Float     @default(1.0)
  isActive        Boolean   @default(false)
  activatedAt     DateTime?
  deactivatedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model IdempotencyRecord {
  key         String    @id @unique
  status      String    // e.g., 'PENDING', 'COMPLETED', 'FAILED'
  requestHash String    // A hash of the original request payload for validation
  response    Json?     // The stored response to return for duplicate requests
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime? // Optional: for automatic cleanup of old records
}

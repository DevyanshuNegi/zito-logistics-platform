generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                    @id @default(uuid())
  fullName              String?
  companyName           String?
  email                 String?                   @unique
  phone                 String                    @unique
  password              String?
  role                  UserRole                  @default(CUSTOMER)
  status                AccountStatus             @default(PENDING)
  agencyId              String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  auditLogs             AuditLog[]
  disbursementsApproved Disbursement[]            @relation("DisbursementApprover")
  disbursementsReceived Disbursement[]            @relation("DisbursementBeneficiary")
  disbursementsCreated  Disbursement[]            @relation("DisbursementCreator")
  ownedDrivers          Driver[]                  @relation("DriverOwner")
  driverProfile         Driver?
  kycDocuments          KycDocument[]
  reportedLosses        LossReport[]              @relation("Reporter")
  reviewedLosses        LossReport[]              @relation("Reviewer")
  notifications         Notification[]
  staffProfile          Staff?
  subscription          Subscription?             @relation("UserSubscription")
  assignedTickets       SupportTicket[]           @relation("TicketHandler")
  supportTickets        SupportTicket[]           @relation("TicketRaiser")
  supportMessages       SupportTicketMessage[]    @relation("SupportMessageAuthor")
  agency                Agency?                   @relation(fields: [agencyId], references: [id])
  ownedVehicles         Vehicle[]                 @relation("VehicleOwner")
  certificates          VerificationCertificate[] @relation("UserCertificates")
  verificationFees      VerificationFeePayment[]  @relation("UserVerificationFees")
  wallets               Wallet[]
  managedWarehouses     Warehouse[]               @relation("WarehouseManager")
}

model KycDocument {
  id               String    @id @default(uuid())
  userId           String
  type             String
  fileUrl          String
  status           String    @default("PENDING")
  documentNumber   String?
  issuingAuthority String?
  countryOfIssue   String?
  documentSide     String?
  issueDate        DateTime?
  expiryDate       DateTime?
  reviewNote       String?
  rejectionReason  String?
  verifiedAt       DateTime?
  verifiedBy       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
}

model Agency {
  id         String      @id @default(uuid())
  name       String
  address    String?
  latitude   Float?
  longitude  Float?
  managerId  String?
  status     String      @default("ACTIVE")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  bookings   Booking[]
  staff      Staff[]
  users      User[]
  warehouses Warehouse[]
}

model Staff {
  id         String          @id @default(uuid())
  userId     String          @unique
  scope      StaffScope      @default(AGENCY)
  agencyId   String?
  department StaffDepartment
  role       String
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  agency     Agency?         @relation(fields: [agencyId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@index([userId, scope, department])
}

model Driver {
  id               String             @id @default(uuid())
  userId           String             @unique
  ownerUserId      String?
  isOnline         Boolean            @default(false)
  isAvailable      Boolean            @default(true)
  currentLatitude  Float?
  currentLongitude Float?
  lastLocationAt   DateTime?
  rating           Float              @default(5.0)
  completionRate   Float              @default(0)
  acceptanceRate   Float              @default(0)
  totalTrips       Int                @default(0)
  licenseNumber    String?
  licenseExpiry    DateTime?
  licenseVerified  Boolean            @default(false)
  isBlacklisted    Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  bookings         Booking[]          @relation("AssignedDriver")
  ownerUser        User?              @relation("DriverOwner", fields: [ownerUserId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  assignments      DriverAssignment[] @relation("DriverAssignments")
  incentives       DriverIncentive[]
  payrolls         DriverPayroll[]
  penalties        DriverPenalty[]
  shifts           DriverShift[]
  fuelLogs         FuelLog[]
  vehicle          Vehicle?           @relation("AssignedVehicle")
  breakdowns       VehicleBreakdown[]

  @@index([currentLatitude, currentLongitude])
  @@index([ownerUserId])
}

model DriverShift {
  id               String           @id @default(uuid())
  driverId         String
  shiftStartTime   DateTime
  shiftEndTime     DateTime?
  totalHours       Float?
  tripHours        Float?
  idleHours        Float?
  attendanceStatus AttendanceStatus @default(PRESENT)
  status           String           @default("ACTIVE")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  driver           Driver           @relation(fields: [driverId], references: [id])
}

model DriverPayroll {
  id             String    @id @default(uuid())
  driverId       String
  periodStart    DateTime
  periodEnd      DateTime
  totalTrips     Int       @default(0)
  tripEarnings   Float     @default(0)
  hourlyEarnings Float     @default(0)
  incentiveTotal Float     @default(0)
  penaltyTotal   Float     @default(0)
  netPayout      Float     @default(0)
  status         String    @default("PENDING")
  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  transactionRef String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  driver         Driver    @relation(fields: [driverId], references: [id])
}

model DriverIncentive {
  id        String   @id @default(uuid())
  driverId  String
  type      String
  amount    Float
  reason    String?
  bookingId String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])
}

model DriverPenalty {
  id        String   @id @default(uuid())
  driverId  String
  type      String
  amount    Float
  reason    String
  bookingId String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])
}

model Vehicle {
  id                          String                     @id @default(uuid())
  plateNumber                 String                     @unique
  chassisNumber               String?
  make                        String?
  model                       String?
  year                        Int?
  type                        VehicleType
  status                      VehicleStatus              @default(INACTIVE)
  capacityKg                  Float
  capacityM3                  Float?
  deviceGpsLat                Float?
  deviceGpsLng                Float?
  lastGpsAt                   DateTime?
  insuranceCompany            String?
  insurancePolicyNumber       String?
  insuranceExpiry             DateTime?
  insuranceVerified           Boolean                    @default(false)
  permitExpiry                DateTime?
  permitVerified              Boolean                    @default(false)
  inspectionCertificateExpiry DateTime?
  verificationStatus          String                     @default("PENDING_REVIEW")
  verificationReviewedAt      DateTime?
  verificationReviewedBy      String?
  verificationNote            String?
  rejectionReason             String?
  ownerUserId                 String?
  driverId                    String?                    @unique
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  bookings                    Booking[]                  @relation("BookingVehicle")
  assignments                 DriverAssignment[]         @relation("AssignmentVehicles")
  fuelLogs                    FuelLog[]
  maintenanceLogs             MaintenanceLog[]
  driver                      Driver?                    @relation("AssignedVehicle", fields: [driverId], references: [id])
  ownerUser                   User?                      @relation("VehicleOwner", fields: [ownerUserId], references: [id])
  breakdowns                  VehicleBreakdown[]
  verificationPhotos          VehicleVerificationPhoto[] @relation("VerificationPhotos")

  @@index([ownerUserId])
  @@index([deviceGpsLat, deviceGpsLng])
}

model FuelLog {
  id           String   @id @default(uuid())
  vehicleId    String
  driverId     String?
  bookingId    String?
  fuelExpected Float
  fuelActual   Float
  fuelCost     Float
  variance     Float
  notes        String?
  isFlagged    Boolean  @default(false)
  createdAt    DateTime @default(now())
  booking      Booking? @relation(fields: [bookingId], references: [id])
  driver       Driver?  @relation(fields: [driverId], references: [id])
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id])
}

model VehicleBreakdown {
  id              String    @id @default(uuid())
  vehicleId       String
  driverId        String
  bookingId       String?
  description     String
  latitude        Float?
  longitude       Float?
  status          String    @default("REPORTED")
  backupVehicleId String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  booking         Booking?  @relation(fields: [bookingId], references: [id])
  driver          Driver    @relation(fields: [driverId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
}

model MaintenanceLog {
  id          String    @id @default(uuid())
  vehicleId   String
  type        String
  description String
  cost        Float?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model Booking {
  id                     String                @id @default(uuid())
  reference              String                @unique
  status                 BookingStatus         @default(CREATED)
  serviceType            ServiceType           @default(COURIER)
  capacitySource         BookingCapacitySource @default(CFA_NETWORK)
  customerId             String
  agencyId               String?
  driverId               String?
  vehicleId              String?
  requiredVehicleType    VehicleType?
  baseFare               Float                 @default(0)
  distanceFare           Float                 @default(0)
  stopFare               Float                 @default(0)
  surgeMultiplier        Float                 @default(1.0)
  totalPrice             Float                 @default(0)
  estimatedDistKm        Float                 @default(0)
  cancelledAt            DateTime?
  cancellationReason     String?
  cancelledBy            String?
  deliveryOtp            String?
  deliveryOtpAttempts    Int                   @default(0)
  deliveryOtpLockedUntil DateTime?
  deliveryProofUrl       String?
  deliveredAt            DateTime?
  assignedAt             DateTime?
  acceptedAt             DateTime?
  dispatchLogId          String?
  manuallyAssignedBy     String?
  manuallyAssignedAt     DateTime?
  idempotencyKey         String?               @unique
  cargoType              String?
  cargoWeightKg          Float?
  cargoDescription       String?
  specialInstructions    String?
  isScheduled            Boolean               @default(false)
  tradeMode              FreightTradeMode?
  railCorridorCode       RailCorridorCode?
  originNode             String?
  destinationNode        String?
  containerReference     String?
  billOfLadingNumber     String?
  idfNumber              String?
  pacReady               Boolean               @default(false)
  customsStatus          TradeDocumentStatus?
  icmsStatus             TradeDocumentStatus?
  isFeatured             Boolean               @default(false)
  featuredTier           FeaturedListingTier?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  agency                 Agency?               @relation(fields: [agencyId], references: [id])
  driver                 Driver?               @relation("AssignedDriver", fields: [driverId], references: [id])
  vehicle                Vehicle?              @relation("BookingVehicle", fields: [vehicleId], references: [id])
  quote                  BookingQuote?
  stops                  BookingStop[]
  assignments            DriverAssignment[]    @relation("BookingAssignments")
  escrow                 Escrow?
  featuredListing        FeaturedListing?
  freightMilestones      FreightMilestone[]
  fuelLogs               FuelLog[]
  parcels                InventoryItem[]
  invoice                Invoice?
  lossReports            LossReport[]
  payments               Payment[]
  rtoReturn              RtoReturn?
  scanEvents             ScanEvent[]
  supportTickets         SupportTicket[]
  breakdowns             VehicleBreakdown[]
  waybills               Waybill[]
}

model DriverAssignment {
  id                      String                 @id @default(uuid())
  bookingId               String
  driverId                String
  vehicleId               String?
  status                  DriverAssignmentStatus @default(OFFERED)
  offeredAt               DateTime               @default(now())
  acceptedAt              DateTime?
  rejectedAt              DateTime?
  rejectionReason         String?
  reassignedAt            DateTime?
  completedAt             DateTime?
  matchScore              Float?
  priorityScore           Float?
  distanceKm              Float?
  estimatedArrivalMinutes Int?
  manuallyOfferedBy       String?
  manuallyOfferedAt       DateTime?
  radiusKmAtOffer         Int?                   @default(10)
  attemptNumber           Int                    @default(1)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  booking                 Booking                @relation("BookingAssignments", fields: [bookingId], references: [id])
  driver                  Driver                 @relation("DriverAssignments", fields: [driverId], references: [id])
  vehicle                 Vehicle?               @relation("AssignmentVehicles", fields: [vehicleId], references: [id])

  @@index([bookingId, status])
  @@index([driverId, status])
  @@index([offeredAt])
}

model VehicleVerificationPhoto {
  id          String                  @id @default(uuid())
  vehicleId   String
  photoType   VehiclePhotoType
  photoUrl    String
  status      PhotoVerificationStatus @default(PENDING_REVIEW)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  timestamp   DateTime?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  vehicle     Vehicle                 @relation("VerificationPhotos", fields: [vehicleId], references: [id])

  @@index([vehicleId, photoType])
  @@index([status])
}

model FreightMilestone {
  id            String    @id @default(uuid())
  bookingId     String
  sequence      Int
  code          String
  title         String
  nodeLabel     String?
  status        String    @default("PENDING")
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  blockedReason String?
  note          String?
  recordedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  booking       Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId, sequence])
}

model BookingQuote {
  id                  String    @id @default(uuid())
  bookingId           String    @unique
  quotedPrice         Float
  currency            String    @default("KES")
  validityStartsAt    DateTime  @default(now())
  validityExpiresAt   DateTime
  quotedBy            String
  quotedAt            DateTime  @default(now())
  acceptedAt          DateTime?
  acceptedBy          String?
  rejectedAt          DateTime?
  rejectionReason     String?
  revisionRequestedAt DateTime?
  revisionNote        String?
  terms               String?
  paymentTerms        String?
  specialConditions   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  booking             Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId, validityExpiresAt])
}

model BookingStop {
  id           String    @id @default(uuid())
  bookingId    String
  sequence     Int
  address      String
  latitude     Float
  longitude    Float
  landmark     String?
  contactName  String
  contactPhone String
  stopType     String
  arrivalTime  DateTime?
  completedAt  DateTime?
  otp          String?
  createdAt    DateTime  @default(now())
  booking      Booking   @relation(fields: [bookingId], references: [id])
}

model RtoReturn {
  id          String     @id @default(uuid())
  bookingId   String     @unique
  reason      String
  status      RtoStatus  @default(INITIATED)
  warehouseId String?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  booking     Booking    @relation(fields: [bookingId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
}

model RateCard {
  id              String      @id @default(uuid())
  vehicleType     VehicleType
  serviceType     ServiceType
  countryCode     String      @default("KE")
  county          String?
  localityType    String      @default("ANY")
  baseFare        Float
  ratePerKm       Float
  perStopRate     Float       @default(0)
  minDistance     Float       @default(0)
  surgeMultiplier Float       @default(1.0)
  isActive        Boolean     @default(true)
  version         Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([countryCode, county, localityType, vehicleType, serviceType, isActive])
}

model Contract {
  id              String    @id @default(uuid())
  customerId      String
  agencyId        String?
  businessName    String
  creditLimit     Float     @default(0)
  creditUsed      Float     @default(0)
  billingCycle    String    @default("MONTHLY")
  paymentTermDays Int       @default(30)
  status          String    @default("ACTIVE")
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LoginOtp {
  id          String   @id @default(uuid())
  contact     String
  otp         String
  expiresAt   DateTime
  resendCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([contact])
}

model LoginAttempt {
  identifier    String    @id
  count         Int       @default(0)
  lastAttemptAt DateTime  @default(now())
  lockExpiresAt DateTime?
}

model Warehouse {
  id         String             @id @default(uuid())
  name       String
  code       String             @unique
  address    String?
  latitude   Float?
  longitude  Float?
  status     String             @default("ACTIVE")
  agencyId   String
  managerId  String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  items      InventoryItem[]
  rtoReturns RtoReturn[]
  agency     Agency             @relation(fields: [agencyId], references: [id])
  manager    User?              @relation("WarehouseManager", fields: [managerId], references: [id])
  listings   WarehouseListing[]
  zones      WarehouseZone[]
}

model WarehouseListing {
  id                 String             @id @default(uuid())
  warehouseId        String
  partnerId          String
  companyName        String
  companyEmail       String?
  companyPhone       String?
  vatNumber          String?
  vatRatePct         Float              @default(0)
  vatApplies         Boolean            @default(false)
  title              String
  description        String?
  areaLabel          String
  address            String
  latitude           Float?
  longitude          Float?
  serviceRadiusKm    Float?
  storageTypes       Json
  amenities          Json
  photoUrls          Json
  documentUrls       Json
  totalCapacity      Float
  availableCapacity  Float
  capacityUnit       String             @default("SQM")
  rateAmount         Float
  rateUnit           String             @default("DAY")
  handlingFee        Float              @default(0)
  minimumBookingDays Int                @default(1)
  status             String             @default("PENDING_REVIEW")
  reviewNote         String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  bookings           WarehouseBooking[]
  warehouse          Warehouse          @relation(fields: [warehouseId], references: [id])

  @@index([partnerId, status])
  @@index([areaLabel, status])
  @@index([warehouseId])
}

model WarehouseBooking {
  id                String           @id @default(uuid())
  reference         String           @unique
  listingId         String
  customerId        String
  partnerId         String
  status            String           @default("REQUESTED")
  storageType       String
  goodsDescription  String
  startDate         DateTime
  endDate           DateTime
  capacityRequested Float
  capacityUnit      String           @default("SQM")
  baseAmount        Float
  handlingFee       Float            @default(0)
  vatAmount         Float            @default(0)
  totalAmount       Float
  commissionRatePct Float            @default(10)
  commissionAmount  Float
  partnerNetAmount  Float
  customerNote      String?
  partnerNote       String?
  adminNote         String?
  acceptedAt        DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  listing           WarehouseListing @relation(fields: [listingId], references: [id])

  @@index([customerId, status])
  @@index([partnerId, status])
  @@index([listingId])
}

model WarehouseZone {
  id          String          @id @default(uuid())
  name        String
  code        String
  type        String          @default("DRY")
  capacity    Float
  warehouseId String
  racks       WarehouseRack[]
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
}

model WarehouseRack {
  id     String         @id @default(uuid())
  label  String
  zoneId String
  bins   WarehouseBin[]
  zone   WarehouseZone  @relation(fields: [zoneId], references: [id])
}

model WarehouseBin {
  id         String          @id @default(uuid())
  label      String
  isOccupied Boolean         @default(false)
  rackId     String
  items      InventoryItem[]
  rack       WarehouseRack   @relation(fields: [rackId], references: [id])
}

model InventoryItem {
  id               String              @id @default(uuid())
  parcelId         String              @unique
  barcodeUrl       String?
  bookingId        String
  waybillId        String?
  ownerId          String
  status           InventoryStatus     @default(RECEIVED)
  isFragile        Boolean             @default(false)
  isHazmat         Boolean             @default(false)
  weight           Float
  dimensions       String?
  expiryDate       DateTime?
  warehouseId      String?
  binId            String?
  currentVehicleId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  bin              WarehouseBin?       @relation(fields: [binId], references: [id])
  booking          Booking             @relation(fields: [bookingId], references: [id])
  warehouse        Warehouse?          @relation(fields: [warehouseId], references: [id])
  waybill          Waybill?            @relation(fields: [waybillId], references: [id])
  movements        InventoryMovement[]
  lossReports      LossReport[]
  scanEvents       ScanEvent[]
}

model InventoryMovement {
  id                  String        @id @default(uuid())
  itemId              String
  status              String
  locationDescription String
  remarks             String?
  performedBy         String
  createdAt           DateTime      @default(now())
  item                InventoryItem @relation(fields: [itemId], references: [id])
}

model ScanEvent {
  id          String         @id @default(uuid())
  itemId      String
  bookingId   String?
  waybillId   String?
  vehicleId   String?
  driverId    String?
  checkpoint  ScanCheckpoint
  latitude    Float?
  longitude   Float?
  performedBy String
  notes       String?
  createdAt   DateTime       @default(now())
  booking     Booking?       @relation(fields: [bookingId], references: [id])
  item        InventoryItem  @relation(fields: [itemId], references: [id])
  waybill     Waybill?       @relation(fields: [waybillId], references: [id])
}

model Waybill {
  id          String          @id @default(uuid())
  number      String          @unique
  type        String          @default("WAYBILL")
  status      WaybillStatus   @default(CREATED)
  isLocked    Boolean         @default(false)
  bookingId   String
  issuedAt    DateTime        @default(now())
  deliveredAt DateTime?
  items       InventoryItem[]
  scanEvents  ScanEvent[]
  booking     Booking         @relation(fields: [bookingId], references: [id])
}

model LossReport {
  id                   String           @id @default(uuid())
  bookingId            String
  itemId               String?
  type                 String
  description          String
  estimatedValue       Float
  status               LossReportStatus @default(PENDING)
  resolutionNotes      String?
  evidenceUrls         String[]
  isHighValue          Boolean          @default(false)
  requiresDualApproval Boolean          @default(false)
  reportedBy           String
  reviewerId           String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  booking              Booking          @relation(fields: [bookingId], references: [id])
  item                 InventoryItem?   @relation(fields: [itemId], references: [id])
  reporter             User             @relation("Reporter", fields: [reportedBy], references: [id])
  reviewer             User?            @relation("Reviewer", fields: [reviewerId], references: [id])
}

model Payment {
  id                               String         @id @default(uuid())
  bookingId                        String?
  invoiceId                        String?
  amount                           Float
  method                           PaymentMethod
  status                           PaymentStatus  @default(INITIATED)
  reference                        String?
  proofUrl                         String?
  provider                         String?
  providerMode                     String?
  providerStatus                   String?
  merchantRequestId                String?
  checkoutRequestId                String?
  providerReceiptNumber            String?
  providerConversationId           String?
  providerOriginatorConversationId String?
  providerPayload                  Json?
  callbackReceivedAt               DateTime?
  confirmedAt                      DateTime?
  idempotencyKey                   String?        @unique
  retryCount                       Int            @default(0)
  failureReason                    String?
  reversedAt                       DateTime?
  createdAt                        DateTime       @default(now())
  updatedAt                        DateTime       @updatedAt
  disbursements                    Disbursement[]
  booking                          Booking?       @relation(fields: [bookingId], references: [id])
  invoice                          Invoice?       @relation(fields: [invoiceId], references: [id])

  @@index([bookingId])
  @@index([invoiceId])
}

model Disbursement {
  id                               String             @id @default(uuid())
  beneficiaryUserId                String?
  createdByUserId                  String
  approvedByUserId                 String?
  sourcePaymentId                  String?
  sourceInvoiceId                  String?
  rail                             DisbursementRail
  status                           DisbursementStatus @default(CREATED)
  amount                           Float
  currency                         String             @default("KES")
  reference                        String             @unique
  purpose                          String
  beneficiaryName                  String
  beneficiaryPhone                 String?
  beneficiaryPartyNumber           String?
  accountReference                 String?
  provider                         String?
  providerMode                     String?
  providerStatus                   String?
  providerReceiptNumber            String?
  providerConversationId           String?
  providerOriginatorConversationId String?
  providerPayload                  Json?
  failureReason                    String?
  initiatedAt                      DateTime?
  processedAt                      DateTime?
  reversedAt                       DateTime?
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  approvedByUser                   User?              @relation("DisbursementApprover", fields: [approvedByUserId], references: [id])
  beneficiaryUser                  User?              @relation("DisbursementBeneficiary", fields: [beneficiaryUserId], references: [id])
  createdByUser                    User               @relation("DisbursementCreator", fields: [createdByUserId], references: [id])
  sourceInvoice                    Invoice?           @relation(fields: [sourceInvoiceId], references: [id])
  sourcePayment                    Payment?           @relation(fields: [sourcePaymentId], references: [id])

  @@index([rail, status])
  @@index([beneficiaryUserId])
  @@index([sourcePaymentId])
  @@index([sourceInvoiceId])
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String
  balance      Float               @default(0)
  currency     String              @default("KES")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id             String   @id @default(uuid())
  walletId       String
  type           String
  amount         Float
  balance        Float
  reference      String?
  description    String?
  bookingId      String?
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  wallet         Wallet   @relation(fields: [walletId], references: [id])
}

model Escrow {
  id          String       @id @default(uuid())
  bookingId   String       @unique
  amount      Float
  status      EscrowStatus @default(HELD)
  heldAt      DateTime     @default(now())
  releasedAt  DateTime?
  refundedAt  DateTime?
  releaseNote String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  booking     Booking      @relation(fields: [bookingId], references: [id])
}

model Invoice {
  id                 String            @id @default(uuid())
  number             String            @unique
  type               InvoiceType
  status             InvoiceStatus     @default(DRAFT)
  isLocked           Boolean           @default(false)
  bookingId          String?           @unique
  customerId         String
  agencyId           String?
  subtotal           Float
  taxAmount          Float             @default(0)
  totalAmount        Float
  paidAmount         Float             @default(0)
  dueDate            DateTime?
  issuedAt           DateTime?
  paidAt             DateTime?
  isApprovalRequired Boolean           @default(false)
  approvedBy         String?
  approvedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  disbursements      Disbursement[]
  booking            Booking?          @relation(fields: [bookingId], references: [id])
  lineItems          InvoiceLineItem[]
  payments           Payment[]
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  totalPrice  Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
}

model SupportTicket {
  id                    String                 @id @default(uuid())
  bookingId             String?
  raisedBy              String
  handlerId             String?
  category              String
  description           String
  status                TicketStatus           @default(OPEN)
  priority              String                 @default("MEDIUM")
  sourceContextType     String?
  sourceContextId       String?
  autobotSummary        String?
  autobotArticle        String?
  autobotConfidence     String?
  autobotQuickAction    String?
  autobotEscalationDesk String?
  autobotSuggestedReply String?
  resolution            String?
  closedAt              DateTime?
  escalationLevel       Int                    @default(1)
  escalatedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  booking               Booking?               @relation(fields: [bookingId], references: [id])
  handler               User?                  @relation("TicketHandler", fields: [handlerId], references: [id])
  raiser                User                   @relation("TicketRaiser", fields: [raisedBy], references: [id])
  messages              SupportTicketMessage[]
}

model SupportTicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  authorId   String?
  actorType  String
  message    String
  isInternal Boolean       @default(false)
  createdAt  DateTime      @default(now())
  author     User?         @relation("SupportMessageAuthor", fields: [authorId], references: [id])
  ticket     SupportTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  title      String
  message    String
  channel    String
  status     String    @default("PENDING")
  retryCount Int       @default(0)
  readAt     DateTime?
  entityType String?
  entityId   String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
}

model InternalAlert {
  id         String   @id @default(uuid())
  type       String
  severity   String   @default("MEDIUM")
  message    String
  status     String   @default("PENDING")
  agencyId   String?
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model FraudFlag {
  id          String    @id @default(uuid())
  entityType  String
  entityId    String
  type        String
  description String
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model SurgeZone {
  id              String    @id @default(uuid())
  name            String
  latitude        Float
  longitude       Float
  radiusKm        Float
  surgeMultiplier Float     @default(1.0)
  isActive        Boolean   @default(false)
  activatedAt     DateTime?
  deactivatedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model IdempotencyRecord {
  key         String    @id @unique
  status      String
  requestHash String
  response    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?
}

model MarketplacePartner {
  userId             String    @id
  partnerType        String
  companyName        String
  serviceAreas       Json
  vehicleIds         Json
  warehouseIds       Json
  baseLatitude       Float?
  baseLongitude      Float?
  serviceRadiusKm    Float?
  commissionRatePct  Float     @default(12)
  serviceFeeFlat     Float     @default(0)
  premiumListing     Boolean   @default(false)
  verificationStatus String    @default("PENDING_REVIEW")
  verificationNote   String?
  submittedBy        String
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectedAt         DateTime?
  suspendedBy        String?
  suspendedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([partnerType, verificationStatus])
  @@index([updatedAt])
}

model MarketplaceOpportunity {
  bookingId         String           @id
  bookingReference  String
  serviceType       ServiceType
  partnerType       String
  pricingModel      String
  status            String           @default("OPEN")
  publishedBy       String
  publishedAt       DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  expiresAt         DateTime?
  currency          String           @default("KES")
  bookingPrice      Float            @default(0)
  fixedPrice        Float?
  minimumBid        Float?
  serviceAreaHints  Json
  stopPoints        Json
  routeSummary      Json
  stopSummary       Json
  fleetRequirements Json
  awardedPartnerId  String?
  selectedBidId     String?
  awardedAt         DateTime?
  awardedBy         String?
  commissionAmount  Float?
  commissionRatePct Float?
  serviceFeeFlat    Float?
  premiumListingFee Float?
  partnerNetAmount  Float?
  bids              MarketplaceBid[]

  @@index([partnerType, status])
  @@index([publishedAt])
  @@index([expiresAt])
}

model MarketplaceBid {
  id                   String                 @id
  opportunityBookingId String
  partnerId            String
  amount               Float
  note                 String?
  submittedAt          DateTime               @default(now())
  status               String                 @default("PENDING")
  counterAmount        Float?
  respondedAt          DateTime?
  respondedBy          String?
  opportunity          MarketplaceOpportunity @relation(fields: [opportunityBookingId], references: [bookingId], onDelete: Cascade)

  @@index([opportunityBookingId, status])
  @@index([partnerId, status])
}

model Subscription {
  id              String               @id @default(uuid())
  userId          String               @unique
  tier            SubscriptionTier     @default(FREE)
  monthlyPrice    Int                  @default(0)
  status          SubscriptionStatus   @default(ACTIVE)
  startDate       DateTime             @default(now())
  nextBillingDate DateTime
  cancelledDate   DateTime?
  expiresAt       DateTime?
  autoRenew       Boolean              @default(true)
  failedAttempts  Int                  @default(0)
  paymentMethod   String               @default("MPESA")
  cancelReason    String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation("UserSubscription", fields: [userId], references: [id], onDelete: Cascade)
  charges         SubscriptionCharge[]

  @@index([userId, status])
  @@index([status, nextBillingDate])
}

model SubscriptionCharge {
  id                   String                   @id @default(uuid())
  subscriptionId       String
  amount               Int
  chargedDate          DateTime                 @default(now())
  status               SubscriptionChargeStatus @default(PENDING)
  transactionReference String?
  failureReason        String?
  createdAt            DateTime                 @default(now())
  subscription         Subscription             @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([chargedDate])
}

model FeaturedListing {
  id                   String                @id @default(uuid())
  bookingId            String                @unique
  tier                 FeaturedListingTier   @default(FEATURED)
  status               FeaturedListingStatus @default(ACTIVE)
  startDate            DateTime              @default(now())
  expiryDate           DateTime
  durationDays         Int
  totalCost            Int
  transactionReference String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  booking              Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, expiryDate])
  @@index([tier])
}

model VerificationFeePayment {
  id                     String    @id @default(uuid())
  userId                 String
  amount                 Int
  processingMode         String    @default("EXPEDITED")
  status                 String    @default("PAID")
  paidAt                 DateTime  @default(now())
  completedAt            DateTime?
  refundedAt             DateTime?
  expectedCompletionDate DateTime?
  transactionReference   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation("UserVerificationFees", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expectedCompletionDate])
}

model VerificationCertificate {
  id                String   @id @default(uuid())
  userId            String
  certificateNumber String   @unique
  status            String   @default("ACTIVE")
  issuedBy          String
  issuedAt          DateTime @default(now())
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation("UserCertificates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}


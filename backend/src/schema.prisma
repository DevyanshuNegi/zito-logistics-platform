// ZITO PRD v8.0 - Industry Standard Edition
// §5.2 Database — PostgreSQL 16 + PostGIS
datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// §4.0 User Roles
enum Role {
  super_admin
  operations_admin
  finance_admin
  call_centre_agent
  customer
  driver
  transporter
  agent
  agency
  warehouse_partner
  sgr_operator
}

enum BookingStatus {
  pending
  approved
  assigned
  accepted
  picked_up
  in_transit
  delivered
  payment_pending
  completed
  cancelled
  rejected
  frozen_sos
}

enum VehicleType {
  motorcycle
  pickup_truck
  van
  light_truck
  heavy_truck
}

enum StorageType {
  dry
  cold
  bonded
  open_yard
  hazmat
  rack
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String    @unique
  role              Role
  full_name         String
  idNumber          String?
  passwordHash      String
  complianceStatus  String    @default("pending")
  dataLocked        Boolean   @default(false)
  isActive          Boolean   @default(true)
  transporterId     String?
  agentId           String?
  agencyId          String?
  
  bookings          Booking[] @relation("CustomerBookings")
  storageBookings   StorageBooking[]
  auditLogs         AuditLog[]
  webhooks          Webhook[]
  notifications     Notification[]
  contracts         Contract[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? @map("deleted_at")

  @@map("users")
}

model Driver {
  id                String    @id @default(uuid())
  userId            String    @unique
  licenseNumber     String
  licenseClass      String
  vehicleId         String?
  avgRating         Decimal   @default(0.0) @db.Decimal(3,2)
  isAvailable       Boolean   @default(false)
  isBlacklisted     Boolean   @default(false)
  canReceiveAssignments Boolean @default(false)
  
  // §5.2 PostGIS Geography point for radius matching
  location          Unsupported("geography(Point, 4326)")?
  lastLocationAt    DateTime?
  
  assignedBookings  Booking[]
  lclRuns           LclRun[]
  locationHistory   DriverLocationHistory[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("drivers")
}

model Vehicle {
  id                String    @id @default(uuid())
  plateNumber       String    @unique
  make              String
  model             String
  vehicleType       VehicleType
  transporterId     String?
  cargoCapacityKg   Decimal   @db.Decimal(10,2)
  isEv              Boolean   @default(false)
  isVerified        Boolean   @default(false)
  isAssignmentBlocked Boolean @default(false)
  
  bookings          Booking[]
  lclRuns           LclRun[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@map("vehicles")
}

model Booking {
  id                      String        @id @default(uuid())
  reference               String        @unique
  status                  BookingStatus @default(pending)
  customerId              String
  assignedDriverId        String?
  vehicleId               String?
  customerRate            Decimal       @db.Decimal(12,2)
  hireRate                Decimal       @db.Decimal(12,2)
  paymentStatus           String        @default("pending")
  isHighValue             Boolean       @default(false)
  shareableTrackingToken  String?       @unique
  consigneeOtpVerified    Boolean       @default(false)
  
  pickupAddress           String
  pickupLat               Decimal?      @db.Decimal(10,8)
  pickupLng               Decimal?      @db.Decimal(11,8)
  deliveryAddress         String
  deliveryLat             Decimal?      @db.Decimal(10,8)
  deliveryLng             Decimal?      @db.Decimal(11,8)
  consigneePhone          String?

  customer                User          @relation("CustomerBookings", fields: [customerId], references: [id])
  driver                  Driver?       @relation(fields: [assignedDriverId], references: [id])
  vehicle                 Vehicle?      @relation(fields: [vehicleId], references: [id])

  tripCharges             TripCharge[]
  payments                Payment[]
  offers                  BookingOffer[]
  sgrBooking              SgrBooking?

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  deletedAt               DateTime?

  @@index([status, createdAt])
  @@map("bookings")
}

model WarehousePartner {
  id                String    @id @default(uuid())
  userId            String    @unique
  name              String
  businessReg       String
  address           String
  location          Unsupported("geography(Point, 4326)")?
  totalCapacitySqft Decimal   @db.Decimal(12,2)
  commissionRate    Decimal   @default(10.00) @db.Decimal(5,2)
  isActive          Boolean   @default(false)
  
  spaces            WarehouseSpace[]
  storageBookings   StorageBooking[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("warehouse_partners")
}

model WarehouseSpace {
  id                String    @id @default(uuid())
  partnerId         String
  zoneName          String
  storageType       StorageType
  ratePerUnit       Decimal   @db.Decimal(10,2)
  isAvailable       Boolean   @default(true)
  
  partner           WarehousePartner @relation(fields: [partnerId], references: [id])
  bookings          StorageBooking[]

  @@map("warehouse_spaces")
}

model StorageBooking {
  id                String    @id @default(uuid())
  customerId        String
  partnerId         String
  spaceId           String
  status            String    @default("pending")
  customerRate      Decimal   @db.Decimal(12,2)
  startDate         DateTime
  endDate           DateTime

  customer          User      @relation(fields: [customerId], references: [id])
  partner           WarehousePartner @relation(fields: [partnerId], references: [id])
  space             WarehouseSpace @relation(fields: [spaceId], references: [id])
  inventory         InventoryRecord[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("storage_bookings")
}

model InventoryRecord {
  id                String    @id @default(uuid())
  storageBookingId  String
  sku               String
  quantityCurrent   Decimal   @db.Decimal(10,3)
  grnPhotoUrl       String?

  booking           StorageBooking @relation(fields: [storageBookingId], references: [id])

  @@map("inventory_records")
}

model LclRun {
  id                      String      @id @default(uuid())
  routeName               String
  vehicleType             VehicleType
  fillPercent             Decimal     @default(0.00) @db.Decimal(5,2)
  status                  String      @default("consolidating")
  windowClosesAt          DateTime
  alertSent30min          Boolean     @default(false) @map("alert_sent_30min")
  
  driverId                String?
  vehicleId               String?
  driver                  Driver?     @relation(fields: [driverId], references: [id])
  vehicle                 Vehicle?    @relation(fields: [vehicleId], references: [id])
  parcels                 LclParcel[]

  createdAt               DateTime    @default(now())

  @@map("lcl_runs")
}

model LclParcel {
  id                String    @id @default(uuid())
  runId             String
  customerId        String
  weightKg          Decimal   @db.Decimal(10,3)
  status            String    @default("pending")

  run               LclRun    @relation(fields: [runId], references: [id])

  @@map("lcl_parcels")
}

model SgrBooking {
  id                String    @id @default(uuid())
  bookingId         String    @unique
  status            String    @default("pending")
  sgrReference      String?
  cargoQrToken      String?   @unique

  booking           Booking   @relation(fields: [bookingId], references: [id])

  @@map("sgr_bookings")
}

model AuditLog {
  id            String    @id @default(uuid())
  userId        String?
  actingAs      Role
  action        String
  entityType    String
  entityId      String
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id])
  
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model TripCharge {
  id            String    @id @default(uuid())
  bookingId     String
  chargeType    String
  amount        Decimal   @db.Decimal(10,2)
  status        String    @default("pending")

  booking       Booking   @relation(fields: [bookingId], references: [id])
  createdAt     DateTime  @default(now())

  @@map("trip_charges")
}

model Payment {
  id            String    @id @default(uuid())
  bookingId     String
  amount        Decimal   @db.Decimal(12,2)
  method        String
  status        String    @default("pending")
  mpesaRef      String?   @unique

  booking       Booking   @relation(fields: [bookingId], references: [id])
  createdAt     DateTime  @default(now())

  @@map("payments")
}

model Webhook {
  id            String    @id @default(uuid())
  customerId    String
  url           String
  isActive      Boolean   @default(true)
  secretTokenHash String

  customer      User      @relation(fields: [customerId], references: [id])

  @@map("webhooks")
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  type          String
  title         String
  body          String
  isRead        Boolean   @default(false)
  sentAt        DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Contract {
  id                String    @id @default(uuid())
  customerId        String
  status            String    @default("active")
  
  customer          User      @relation(fields: [customerId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("contracts")
}
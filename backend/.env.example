# ═════════════════════════════════════════════════════════════════════════════════
# ZITO BACKEND — ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ═════════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. NEVER commit .env to Git (it's in .gitignore)
# 4. ONLY commit .env.example (with placeholder values)
# 5. Required variables are marked with [REQUIRED]
#
# ═════════════════════════════════════════════════════════════════════════════════

# =========================
# APPLICATION [REQUIRED]
# =========================
NODE_ENV=development
PORT=5000

# =========================
# DATABASE [REQUIRED]
# =========================
# Neon PostgreSQL (managed)
# Format: postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require
# Get pooler host from Neon dashboard: Settings > Connection parameters
DATABASE_URL=postgresql://YOUR_NEON_USER:YOUR_NEON_PASSWORD@YOUR_NEON_PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://YOUR_NEON_USER:YOUR_NEON_PASSWORD@YOUR_NEON_PROJECT.REGION.aws.neon.tech/neondb?sslmode=require

# =========================
# AUTH [REQUIRED]
# =========================
# JWT tokens: use strong, random secrets (minimum 32 characters)
JWT_SECRET=replace_with_a_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_min_32_chars

# =========================
# REDIS (LOCAL OR UPSTASH)
# =========================
# For local development: redis://localhost:6379
# For Upstash: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# =========================
# FRONTEND URLS
# =========================
# Production must use deployed HTTPS origins only. Do not include localhost in production.
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# =========================
# SECURITY / ABUSE LIMITS
# =========================
# Required in production. Tune after load testing.
RATE_LIMIT_PER_MINUTE=300
AUTH_RATE_LIMIT_PER_15_MINUTES=30

# =========================
# EMAIL (RESEND)
# =========================
RESEND_API_KEY=re_your_resend_api_key_here
MAIL_FROM=no-reply@aurenza.local

# =========================
# SMS (AFRICA'S TALKING)
# =========================
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key_here

# =========================
# OTP PROVIDER
# =========================
# Use OTP_MODE=test for local/internal QA with no SMS cost.
# Production must use OTP_MODE=twilio until another live provider is approved.
OTP_MODE=test
TEST_OTP_CODE=123456

# Twilio Verify remains available for staging, UAT, and production.
OTP_PROVIDER=twilio_verify
TWILIO_VERIFY_ENABLED=false
# Testing-only phone OTP relay via Twilio Verify.
# Keep OTP_TEST_REDIRECT_ENABLED=false unless you intentionally want every phone OTP
# delivered to one fixed test number in non-production.
TWILIO_VERIFY_SERVICE_SID=VA_your_service_sid_here
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
OTP_TEST_REDIRECT_ENABLED=false
OTP_TEST_REDIRECT_PHONE=+254745000000
# Optional Android SMS Retriever hash for OTP auto-fill in the mobile app.
TWILIO_VERIFY_ANDROID_APP_HASH=

# =========================
# JOB QUEUE (BULLMQ)
# =========================
BULLMQ_ENABLED=true
BULLMQ_QUEUE_NAME=zito-jobs
BULLMQ_DEAD_LETTER_QUEUE=zito-dead-letter

# =========================
# M-PESA PAYMENT (DARAJA API)
# =========================
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_ENVIRONMENT=sandbox
MPESA_SHORTCODE=your_mpesa_shortcode_here
MPESA_PASSKEY=your_mpesa_passkey_here
# Use localhost for local development, or your deployed backend origin when callbacks are exposed publicly.
MPESA_CALLBACK_URL=http://localhost:5000/api/v1/payments/mpesa/callback
MPESA_RESULT_URL=http://localhost:5000/api/v1/payments/mpesa/result
MPESA_TIMEOUT_URL=http://localhost:5000/api/v1/payments/mpesa/timeout
# Required in production. Configure the same value as a secret header at the callback gateway/proxy/provider integration.
MPESA_CALLBACK_SECRET=replace_with_long_random_callback_secret
# Optional comma-separated source IP allowlist when provider/static gateway IPs are available.
MPESA_CALLBACK_IP_ALLOWLIST=
MPESA_INITIATOR_NAME=your_initiator_name_here
MPESA_SECURITY_CREDENTIAL=your_security_credential_here
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_PARTYB=your_partyb_code_here
MPESA_IDENTIFIER_TYPE=4
MPESA_B2C_COMMAND_ID=BusinessPayment
MPESA_B2B_COMMAND_ID=BusinessPayBill
MPESA_SENDER_IDENTIFIER_TYPE=4
MPESA_RECEIVER_IDENTIFIER_TYPE=4

# =========================
# EXTERNAL SERVICES (OPTIONAL)
# =========================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
SENTRY_DSN=
DATADOG_API_KEY=
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_SUPPORT_MODEL=gpt-4-mini
OPENAI_SUPPORT_ESCALATION_MODEL=gpt-4
OPENAI_SUPPORT_ENABLE_FILE_SEARCH=false

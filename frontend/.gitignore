# ─────────────────────────────────────────────────────────────
#  ZITO — .gitignore
#  Root-level. Covers both /backend and /frontend folders.
#  VG Global Logistics · 2026
# ─────────────────────────────────────────────────────────────

# ── Environment variables — NEVER commit these ───────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*

# ── Dependencies ─────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime / Process ────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Build output ─────────────────────────────────────────────
dist/
build/
frontend/dist/
backend/dist/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Coverage & Testing ────────────────────────────────────────
coverage/
.nyc_output/

# ── Uploads / user-generated files ───────────────────────────
uploads/
backend/uploads/

# ── Optional: lock files (keep these — do NOT ignore) ────────
# package-lock.json  ← keep
# yarn.lock          ← keep
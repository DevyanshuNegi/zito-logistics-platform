{
  "cli": {
    "version": ">= 13.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },
    "customer-preview": {
      "extends": "preview",
      "appBuildGradle": "custom",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview",
        "APP_FLAVOR": "customer"
      },
      "resourceClass": "default"
    },
    "customer-production": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "APP_FLAVOR": "customer"
      }
    },
    "partner-preview": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview",
        "APP_FLAVOR": "partner"
      }
    },
    "partner-production": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "APP_FLAVOR": "partner"
      }
    },
    "admin-preview": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "preview",
        "APP_FLAVOR": "admin"
      }
    },
    "admin-production": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "APP_FLAVOR": "admin"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {}
    },
    "customer-production": {
      "android": {
        "track": "internal"
      },
      "ios": {}
    },
    "partner-production": {
      "android": {
        "track": "internal"
      },
      "ios": {}
    },
    "admin-production": {
      "android": {
        "track": "internal"
      },
      "ios": {}
    }
  }
}

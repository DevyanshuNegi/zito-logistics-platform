# Mobile API base URL used by Expo runtime.
EXPO_PUBLIC_API_URL=https://your-api-host.example.com

# Shared Google Maps key for route, places, and map rendering.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Build labeling for EAS development / preview / production profiles.
EXPO_PUBLIC_APP_ENV=development

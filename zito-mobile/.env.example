# ═════════════════════════════════════════════════════════════════════════════════
# ZITO MOBILE (EXPO) — ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ═════════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT:
# 1. Copy to .env: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git (in .gitignore)
# 4. ONLY commit .env.example (with placeholder values)
#
# NOTE: All EXPO_PUBLIC_* variables are embedded in APK/IPA (visible in client bundle)
#       Do NOT put secrets here. Use backend API for sensitive operations.
#
# ═════════════════════════════════════════════════════════════════════════════════

# =========================
# API BACKEND [REQUIRED]
# =========================
# Local development (Android Emulator): http://10.0.2.2:5000
# Local development (iOS Simulator): http://localhost:5000
# Deployed: https://zito-backend.vercel.app
EXPO_PUBLIC_API_URL=http://localhost:5000

# =========================
# GOOGLE MAPS [REQUIRED FOR LOCATION FEATURES]
# =========================
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =========================
# BUILD ENVIRONMENT
# =========================
# Values: development | preview | production
# Used to configure EAS build profiles and feature flags
EXPO_PUBLIC_APP_ENV=development

# =========================
# OPTIONAL: FEATURE FLAGS
# =========================
# EXPO_PUBLIC_DEBUG_MODE=false
# EXPO_PUBLIC_ANALYTICS_ENABLED=true


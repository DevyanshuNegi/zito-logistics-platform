{
  "name": "zito-mobile",
  "main": "expo-router/entry",
  "description": "Zito mobile app by Aurenza Limited for customers, courier companies, drivers, and transporters.",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "start:phone": "set HTTP_PROXY=&& set HTTPS_PROXY=&& set ALL_PROXY=&& set GIT_HTTP_PROXY=&& set GIT_HTTPS_PROXY=&& set EXPO_NO_CACHE=1&& set NO_PROXY=localhost,127.0.0.1,::1,192.168.0.29&& expo start --clear --max-workers 1 --lan",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "eas:login": "npx eas-cli login",
    "android:preview": "npx eas-cli build --platform android --profile preview",
    "android:playstore": "npx eas-cli build --platform android --profile production",
    "android:submit": "npx eas-cli submit --platform android --profile production",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:preview": "npx eas-cli build --platform ios --profile preview",
    "ios:production": "npx eas-cli build --platform ios --profile production",
    "ios:testflight": "npx eas-cli build --platform ios --profile production",
    "ios:submit": "npx eas-cli submit --platform ios --profile production",
    "build:preview": "npx eas-cli build --platform all --profile preview",
    "build:production": "npx eas-cli build --platform all --profile production",
    "update:android": "npx eas update --platform android",
    "update:ios": "npx eas update --platform ios",
    "update:all": "npx eas update --platform all",
    "doctor": "npx expo-doctor",
    "export:android:debug": "expo export --platform android --clear --max-workers 1 --no-bytecode",
    "web": "expo start --web",
    "lint": "expo lint",
    "customer:preview": "node scripts/build-flavor.js customer preview",
    "customer:production": "node scripts/build-flavor.js customer production",
    "customer:update": "npx eas update --platform android --channel customer-preview",
    "partner:preview": "node scripts/build-flavor.js partner preview",
    "partner:production": "node scripts/build-flavor.js partner production",
    "partner:update": "npx eas update --platform android --channel partner-preview",
    "admin:preview": "node scripts/build-flavor.js admin preview",
    "admin:production": "node scripts/build-flavor.js admin production",
    "admin:update": "npx eas update --platform android --channel admin-preview",
    "build:all-preview": "npm run customer:preview && npm run partner:preview && npm run admin:preview",
    "build:all-production": "npm run customer:production && npm run partner:production && npm run admin:production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-places-autocomplete": "^2.6.4",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "canvas": "^3.2.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}

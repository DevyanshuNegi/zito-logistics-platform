# ─────────────────────────────────────────────────────────────
# ZITO — .gitignore
# Root-level (Backend + Frontend + Mobile)
# PRD Compliant | Production Safe
# ─────────────────────────────────────────────────────────────

# =========================
# Logs
# =========================
logs/*
!logs/README.md
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =========================
# Diagnostic Reports
# =========================
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =========================
# Runtime Data
# =========================
pids
*.pid
*.seed
*.pid.lock

# =========================
# Coverage & Testing
# =========================
coverage
*.lcov
.nyc_output

# =========================
# Build / Cache / Temp
# =========================
dist
build
.cache
.parcel-cache
.temp
.tmp
.next
.next-dev
.next-prod
frontend/.next
frontend/.next-dev
frontend/.next-dev-public
frontend/.next-prod
out
.nuxt
.svelte-kit
.docusaurus
.fusebox
.serverless
.firebase
web_modules
tmp-screens/
.codex-docx-tmp/
.docx-temp/
docs/prd/qa-temp/
outputs/qa-logins/previews/
outputs/qa-logins/*.ndjson
outputs/qa-logins/~$*.xlsx

# =========================
# Dependencies
# =========================
node_modules/
jspm_packages/
bower_components/

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# Package Managers / Cache
# =========================
.npm
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity
.pnp.*

# =========================
# Environment Variables (CRITICAL)
# =========================
.env
.env.*
.env.local
!.env.example

# =========================
# Database / Secrets (CRITICAL)
# =========================
*.sqlite
*.db
*.sql
!backend/prisma/migrations/**/*.sql
*.dump
*.pg_dump

# =========================
# Uploads / Documents (CRITICAL - PRD)
# =========================
uploads/
/storage/
public/uploads/
backend/uploads/
docs/

# =========================
# SSL / TLS Secrets (PRD §11)
# =========================
*.pem
*.key
*.cert

# =========================
# Expo / Mobile (PRD §9)
# =========================
zito-mobile/.expo/
zito-mobile/.expo-shared/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor / IDE
# =========================
.idea/
.vscode-test

# =========================
# Vite / Frontend
# =========================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# =========================
# Misc
# =========================
.lock-wscript
.tern-port
.node_repl_history
*.tgz
.eslintcache
.stylelintcache
.grunt
lib-cov
g/
m/
outputs/chrome-preview-profile/
zito-mobile/.gradle-home/
zito-mobile/.gradle-local/

# =========================
# Optional (Framework Specific)
# =========================
.vuepress/dist
**/.vitepress/dist
**/.vitepress/cache

# =========================
# Security Reminder
# =========================
# NEVER commit:
# - .env files
# - KYC documents
# - Vehicle documents
# - POD images
# - Database dumps
# ─────────────────────────────────────────────────────────────
.vercel

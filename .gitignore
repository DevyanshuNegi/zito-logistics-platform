# ─────────────────────────────────────────────────────────────
# ZITO — .gitignore
# Root-level (Backend + Frontend + Mobile)
# PRD Compliant | Production Safe
# ─────────────────────────────────────────────────────────────

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =========================
# Diagnostic Reports
# =========================
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =========================
# Runtime Data
# =========================
pids
*.pid
*.seed
*.pid.lock

# =========================
# Coverage & Testing
# =========================
coverage
*.lcov
.nyc_output

# =========================
# Build / Cache / Temp
# =========================
dist
build
.cache
.parcel-cache
.temp
.tmp
.next
out
.nuxt
.svelte-kit
.docusaurus
.fusebox
.serverless
.firebase
web_modules

# =========================
# Dependencies
# =========================
node_modules/
jspm_packages/
bower_components/

# =========================
# TypeScript
# =========================
*.tsbuildinfo

# =========================
# Package Managers / Cache
# =========================
.npm
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn-integrity
.pnp.*

# =========================
# Environment Variables (CRITICAL)
# =========================
.env
.env.*
.env.local
!.env.example

# =========================
# Database / Secrets (CRITICAL)
# =========================
*.sqlite
*.db
*.sql
*.dump
*.pg_dump

# =========================
# Uploads / Documents (CRITICAL - PRD)
# =========================
uploads/
storage/
public/uploads/
backend/uploads/

# =========================
# SSL / TLS Secrets (PRD §11)
# =========================
*.pem
*.key
*.cert

# =========================
# Deployment Vendor Local Config
# =========================
.render/

# =========================
# Expo / Mobile (PRD §9)
# =========================
zito-mobile/.expo/
zito-mobile/.expo-shared/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Editor / IDE
# =========================
.vscode-test

# =========================
# Vite / Frontend
# =========================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# =========================
# Misc
# =========================
.lock-wscript
.tern-port
.node_repl_history
*.tgz
.eslintcache
.stylelintcache
.grunt
lib-cov

# =========================
# Optional (Framework Specific)
# =========================
.vuepress/dist
**/.vitepress/dist
**/.vitepress/cache

# =========================
# Security Reminder
# =========================
# NEVER commit:
# - .env files
# - KYC documents
# - Vehicle documents
# - POD images
# - Database dumps
# ─────────────────────────────────────────────────────────────
